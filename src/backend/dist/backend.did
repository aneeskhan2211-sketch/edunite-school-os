   quiz;
   test;
 };
type AssignmentId = nat;
type Assignment = 
 record {
   assignmentType: AssignmentType;
   courseId: CourseId;
   description: opt text;
   dueDate: Timestamp;
   id: AssignmentId;
   isDemoData: bool;
   isHighStakes: bool;
   linkedLessonId: opt LessonId;
   name: text;
   points: float64;
   term: text;
   weight: float64;
 };
type AppointmentType = 
 variant {
   checkIn;
   custom;
   groupSession;
   intervention;
   parentConference;
   referralFollowUp;
 };
type AppointmentStatus = 
 variant {
   cancelled;
   completed;
   scheduled;
 };
type AppointmentId = nat;
type Appointment = 
 record {
   appointmentType: AppointmentType;
   counsellorId: StaffId;
   createdAt: Timestamp;
   dateTime: Timestamp;
   id: AppointmentId;
   isDemoData: bool;
   notes: text;
   status: AppointmentStatus;
   studentId: StudentId;
 };
type AnnouncementPriority = 
 variant {
   important;
   info;
   urgent;
 };
type AnnouncementId = nat;
type Announcement = 
 record {
   authorId: StaffId;
   body: text;
   createdAt: Timestamp;
   id: AnnouncementId;
   isDemoData: bool;
   priority: AnnouncementPriority;
   targetRoles: vec Role;
   title: text;
 };
type ActivityRoster = 
 record {
   activityId: ActivityId;
   joinedAt: int;
   role: variant {
           captain;
           leader;
           member;
         };
   status: variant {
             active;
             inactive;
             waitlisted;
           };
   studentId: text;
 };
type ActivityId = nat;
type Activity = 
 record {
   actType: variant {
              club;
              fineArts;
              serviceHours;
              sport;
            };
   coachAdvisorId: opt text;
   eligibilityAttendanceMin: float64;
   eligibilityGpaMin: float64;
   id: ActivityId;
   maxRoster: opt nat;
   name: text;
   season: opt text;
 };
type Account = 
 record {
   displayName: text;
   isOwner: bool;
   principalText: text;
   role: Role;
   userId: nat;
 };
