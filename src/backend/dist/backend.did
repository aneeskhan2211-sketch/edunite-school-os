      ok: Grade;
    });
  updateGradeCategory: (id: CategoryId, name: text, weight: nat) ->
   (opt GradeCategory);
  updateGradebookAssignment: (id: AssignmentId, name: text, pointsPossible:
   nat, dueDate: opt text) -> (opt AssignmentV2);
  updateIEPRenewalDate: (studentId: StudentId, newDate: Timestamp, updatedBy:
   StaffId) -> (UpdateResult);
  updateIncidentStatus: (id: IncidentId, status: IncidentStatus, note: 
   text, ctx: RoleContext) -> (variant {
                                 err: text;
                                 ok: Incident;
                               });
  updateInterventionOutcome: (interventionId: InterventionId, outcome: 
   text, notes: text) -> (variant {
                            err: text;
                            ok;
                          });
  updateLesson: (lessonId: LessonId, name: opt text, description:
   opt text) -> (variant {
                   err: text;
                   ok: Lesson;
                 });
  updateScore: (id: ScoreId, pointsEarned: opt nat) -> (opt Score);
  updateStudent: (id: StudentId, student: Student) ->
   (variant {
      err: text;
      ok: Student;
    });
  updateUnit: (unitId: UnitId, name: opt text) ->
   (variant {
      err: text;
      ok: Unit;
    });
  whoami: () -> (principal) query;
}
